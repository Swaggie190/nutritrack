# NutriTrack Environment Variables
# Copy this file to .env and fill in your actual API keys

# Claude AI API Key (for meal analysis and nutrition insights)
# Get yours at: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Cohere API Key (for chatbot functionality)
# Get yours at: https://dashboard.cohere.ai/
COHERE_API_KEY=your_cohere_api_key_here

# Google Maps API Key (for restaurant location features)
# Get yours at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
